# Detection backend strategy:
# - Prefer ONNX models (with CUDAExecutionProvider when available)
# - Fallback to PT only if ONNX is unavailable

# Smoke detector (ONNX), class mapping: 0=smoke
SMOKE_ONNX_MODEL=app/models/wildfire-smoke-fire.onnx
SMOKE_PT_MODEL=app/models/wildfire-smoke-fire.pt
SMOKE_MODEL_INCLUDE_FIRE=false
SMOKE_MODEL_FIRE_CLASS_ID=1
SMOKE_MODEL_SMOKE_CLASS_ID=0

# Fire detector must use only_fire.onnx
FIRE_ONNX_MODEL=app/models/only_fire.onnx
FIRE_PT_MODEL=app/models/_disabled_fire.pt

# Garbage detector (prefer ONNX)
GARBAGE_ONNX_MODEL=app/models/garbege.onnx
GARBAGE_PT_MODEL=app/models/_disabled_garbage.pt

# Thresholds
FIRE_CONF_THRESHOLD=0.10
SMOKE_CONF_THRESHOLD=0.22
GARBAGE_BIN_CONF_THRESHOLD=0.30
GARBAGE_LITTER_CONF_THRESHOLD=0.48


