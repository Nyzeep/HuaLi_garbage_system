# Use HuggingFace smoke/fire model: odiug77/wildfire-smoke-fire
SMOKE_PT_MODEL=app/models/wildfire-smoke-fire.pt
# Disable ONNX priority for smoke so PT model is used
SMOKE_ONNX_MODEL=app/models/_disabled_smoke.onnx
# Smoke model only handles smoke (class 0=smoke)
SMOKE_MODEL_INCLUDE_FIRE=false
SMOKE_MODEL_FIRE_CLASS_ID=1
SMOKE_MODEL_SMOKE_CLASS_ID=0
FIRE_CONF_THRESHOLD=0.10
SMOKE_CONF_THRESHOLD=0.30

# Lower garbage-bin threshold to reduce missed bins in hard scenes.
GARBAGE_BIN_CONF_THRESHOLD=0.30

# Use standalone fire model from ONNX
FIRE_ONNX_MODEL=app/models/only_fire.onnx
FIRE_PT_MODEL=app/models/_disabled_fire.pt


