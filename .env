# Use HuggingFace smoke/fire model exported as best.pt
SMOKE_PT_MODEL=app/models/best.pt
# Disable ONNX priority for smoke so PT model is used
SMOKE_ONNX_MODEL=app/models/_disabled_smoke.onnx
# Keep fire class from smoke model enabled (class 0=fire, 1=smoke)
SMOKE_MODEL_INCLUDE_FIRE=true
SMOKE_MODEL_FIRE_CLASS_ID=0
SMOKE_MODEL_SMOKE_CLASS_ID=1
